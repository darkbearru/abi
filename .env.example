NODE_ENV=development
COMPOSE_PROJECT_NAME=ai-book-illustrator

API_PORT=3000
JWT_SECRET=change-me-use-a-long-random-secret
JWT_EXPIRES_IN_SECONDS=604800
ADMIN_USER_IDS=
BOOK_UPLOAD_MAX_BYTES=52428800
BOOK_CHUNK_TARGET_TOKENS=1800
BOOK_CHUNK_OVERLAP_TOKENS=200
CHARACTER_EXTRACTION_AI_PROVIDER=openai
CHARACTER_EXTRACTION_PROMPT_VERSION=1.0.0
CHARACTER_PASSPORT_IMAGE_PROVIDER=openai
CHARACTER_PASSPORT_IMAGE_MODEL=gpt-image-1
CHARACTER_PASSPORT_IMAGE_SIZE=1024x1024
LOCATION_EXTRACTION_AI_PROVIDER=openai
LOCATION_EXTRACTION_PROMPT_VERSION=1.0.0
LOCATION_PASSPORT_IMAGE_PROVIDER=openai
LOCATION_PASSPORT_IMAGE_MODEL=gpt-image-1
LOCATION_PASSPORT_IMAGE_SIZE=1024x1024
SCENE_IMAGE_PROVIDER=openai
SCENE_IMAGE_MODEL=gpt-image-1
SCENE_IMAGE_SIZE=1024x1024
CONSISTENCY_VALIDATION_PROVIDER=mock
CONSISTENCY_VALIDATION_AI_PROVIDER=openai
CONSISTENCY_VALIDATION_AI_MODEL=
TIMELINE_EXTRACTION_AI_PROVIDER=openai
TIMELINE_EXTRACTION_PROMPT_VERSION=1.0.0
WEB_PORT=5173
VITE_API_BASE_URL=http://localhost:3000

POSTGRES_VERSION=16-alpine
POSTGRES_DB=abi
POSTGRES_USER=abi
POSTGRES_PASSWORD=abi
POSTGRES_PORT=5432
DATABASE_URL=postgresql://abi:abi@localhost:5432/abi

REDIS_VERSION=7-alpine
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

QDRANT_VERSION=v1.9.5
QDRANT_HTTP_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION_BOOK_KNOWLEDGE=abi_book_knowledge
VECTOR_EMBEDDING_DIMENSIONS=256

NEO4J_VERSION=5-community
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=please-change-me
NEO4J_HTTP_PORT=7474
NEO4J_BOLT_PORT=7687

STORAGE_ROOT=/app/storage
LOCAL_STORAGE_PATH=../storage
OPENAI_API_KEY=

MINIO_VERSION=RELEASE.2024-06-22T05-26-45Z
MINIO_ENDPOINT=http://localhost:9000
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
